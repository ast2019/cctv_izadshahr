  frigate-{{ instance.name }}:
    container_name: frigate-{{ instance.name }}
    image: {{ g.frigate_image }}
    restart: {{ g.restart_policy }}
    shm_size: "{{ g.shm_size }}"
    stop_grace_period: 30s
    # Ephemeral cache lives in RAM, never on disk.
    tmpfs:
      - /tmp/cache
    # Secrets are injected from the server-side env file; kept optional so that
    # `docker compose config` works in CI where the file is absent.
    env_file:
      - path: ${FRIGATE_ENV_FILE:-{{ g.secrets_env }}}
        required: false
    volumes:
      # Independent config dir per instance (holds config.yml + frigate.db).
      - ${FRIGATE_BASE:-{{ g.base_path }}}/runtime-config/{{ instance.name }}:/config
      # Independent media dir per instance.
      - ${FRIGATE_BASE:-{{ g.base_path }}}/media/{{ instance.name }}:/media/frigate
      - /etc/localtime:/etc/localtime:ro
    ports:
      - "{{ instance.ui_port }}:{{ g.internal_ui_port }}"        # web UI
      - "{{ instance.rtsp_port }}:{{ g.internal_rtsp_port }}"    # RTSP restream
      - "{{ instance.webrtc_port }}:{{ g.internal_webrtc_port }}/tcp"  # WebRTC
      - "{{ instance.webrtc_port }}:{{ g.internal_webrtc_port }}/udp"  # WebRTC
    # JSON Docker logging with rotation.
    logging:
      driver: json-file
      options:
        max-size: "{{ g.log_max_size }}"
        max-file: "{{ g.log_max_file }}"
