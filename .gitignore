# =============================================================================
# Secrets — never commit real credentials
# =============================================================================
.env
*.env
!.env.example

# =============================================================================
# Runtime data & media — never commit
# =============================================================================
media/
runtime-config/**/frigate.db*
runtime-config/**/cache/
runtime-config/**/exports/
runtime-config/**/clips/
runtime-config/**/recordings/

# Server-side backups (produced by scripts/backup-config.sh)
backups/

# =============================================================================
# Generated output — inventory/ is the single source of truth
# =============================================================================
generated/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
.venv/
venv/

# =============================================================================
# Editor / OS cruft
# =============================================================================
.DS_Store
*.swp
