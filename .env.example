# SSL + Let's Encrypt (optional)
# Copy to .env and run: ./scripts/init-ssl.sh
#
# CCTV_DOMAIN=cctv.shahrhotel.ir
# CCTV_EMAIL=admin@shahrhotel.ir
#
# DNS records required (point to server public IP):
#   cctv.shahrhotel.ir       → portal
#   cafe.cctv.shahrhotel.ir  → frigate-cafe (via nginx)
#   center11.cctv.shahrhotel.ir → frigate-center11
#
# Let's Encrypt cannot issue certificates for bare IP addresses (192.168.x.x).
